<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
</head>

<body>
    <h1>Todos os Post</h1>

    <a href="/create">
        <button>Novo Post</button>
    </a>

    <% if (locals.posts) { %>
        <% posts.forEach(post=> { %>
            <h2>
                <%= post.title %>
            </h2>
            <p>
                <%= post.comment %>
            </p>
            <% })}; %>
</body>

</html>